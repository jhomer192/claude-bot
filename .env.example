# Copy to .env (local dev) or /etc/claude-bot.env (production) and fill in.

# Leave blank to use Claude Max/Pro subscription (run `claude login` on the host).
# Only set if you want API billing instead.
ANTHROPIC_API_KEY=

# Talk to @BotFather on Telegram, /newbot, follow prompts, copy the token it gives you.
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram user IDs allowed to message the bot.
# To find yours: message @userinfobot on Telegram, it replies with your numeric ID.
TELEGRAM_ALLOWED_USER_IDS=

# Fine-grained PAT. Scope to the repos you want the bot touching, contents:rw + pull_requests:rw.
# Get one at https://github.com/settings/personal-access-tokens/new
GITHUB_TOKEN=

# Paths. Defaults shown match the production layout; override for local dev.
WORKSPACE_DIR=/home/claude/workspace
STATE_DB_PATH=/var/lib/claude-bot/state.db

# Hard cap on spend per chat per UTC day. Bot refuses further turns once exceeded.
DAILY_COST_CAP_USD=5

# Optional: path to MCP servers config (JSON). Leave blank to disable.
MCP_CONFIG_PATH=
